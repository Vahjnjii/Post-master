# Environment Variables for Cloudflare/Github Migration

# Generate a random string for JWT
JWT_SECRET=your_jwt_secret_here

# For Google OAuth (Cloudflare compatible)
# You will need to get these from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The URL of your app (used for redirects)
# In production, this will be your .pages.dev or .run.app URL
APP_URL=http://localhost:3000

# Gemini API Key (handled by platform in AI Studio)
GEMINI_API_KEY=
